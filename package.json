{
  "name": "orkestra",
  "version": "0.1.0",
  "description": "Camada de seleção, comparação e recomendação de LLMs sobre o OpenRouter (BYOK).",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "tsx src/index.ts",
    "build:web": "npm --prefix web ci && npm --prefix web run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"{src,tests,scripts}/**/*.ts\"",
    "format:check": "prettier --check \"{src,tests,scripts}/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "tsx scripts/smoke.ts",
    "loadtest": "autocannon -c 20 -d 10 http://localhost:3000/health"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vanhalen/orkestra.git"
  },
  "keywords": [
    "llm",
    "openrouter",
    "ai",
    "model-selection",
    "model-comparison",
    "fastify",
    "byok"
  ],
  "author": "Rodrigo Chagas <contato@rodrigorchagas.com.br>",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/vanhalen/orkestra/issues"
  },
  "homepage": "https://github.com/vanhalen/orkestra#readme",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^24.13.0",
    "autocannon": "^8.0.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
