{
  "name": "orkestra",
  "version": "0.1.0",
  "description": "Camada de seleção, comparação e recomendação de LLMs sobre o OpenRouter (BYOK).",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"{src,tests}/**/*.ts\"",
    "format:check": "prettier --check \"{src,tests}/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vanhalen/orkestra.git"
  },
  "keywords": [
    "llm",
    "openrouter",
    "ai",
    "model-selection",
    "model-comparison",
    "fastify",
    "byok"
  ],
  "author": "Rodrigo Chagas <contato@rodrigorchagas.com.br>",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/vanhalen/orkestra/issues"
  },
  "homepage": "https://github.com/vanhalen/orkestra#readme",
  "dependencies": {
    "@openrouter/sdk": "^0.5.1",
    "fastify": "^5.7.4",
    "fastify-type-provider-zod": "^6.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^24.13.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
