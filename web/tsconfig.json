{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "preserve",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "skipLibCheck": true,
        "noEmit": true,
        "isolatedModules": true,
        "types": ["vite/client"]
    },
    "include": ["src", "vite.config.ts"]
}
