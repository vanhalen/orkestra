# Configuração do SERVIDOR Orkestra.
# A API key do OpenRouter NÃO vai aqui: é BYOK, enviada por requisição no header
# Authorization. Todas as variáveis abaixo são opcionais (têm default).

PORT=3000
HOST=0.0.0.0

# Origem permitida no CORS (a SPA de divulgação). Use a URL do front em dev.
WEB_ORIGIN=http://localhost:5173

# Timeout por chamada a modelo no OpenRouter (ms).
REQUEST_TIMEOUT_MS=30000

# TTL do cache do catálogo de modelos (ms).
CATALOG_TTL_MS=300000

# Rate limit: máximo de requisições por IP por minuto.
RATE_LIMIT_MAX=120

# Limite do corpo da requisição em bytes (PDFs em base64). Padrão: 10 MB.
MAX_BODY_BYTES=10485760

# Headers enviados ao OpenRouter (defaults; podem ser sobrescritos por requisição).
HTTP_REFERER=http://localhost:3000
TITLE=Orkestra
